<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>contextrot report</title>
<style>
  :root {
    --surface-1: #fcfcfb; --page: #f9f9f7;
    --ink-1: #0b0b0b; --ink-2: #52514e; --ink-muted: #898781;
    --grid: #e1e0d9; --baseline: #c3c2b7; --ring: rgba(11,11,11,0.10);
    --series-1: #2a78d6; --series-2: #1baf7a; --series-3: #eda100; --series-4: #008300;
    --critical: #d03b3b; --warning: #b97d00; --good: #006300;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --surface-1: #1a1a19; --page: #0d0d0d;
      --ink-1: #ffffff; --ink-2: #c3c2b7; --ink-muted: #898781;
      --grid: #2c2c2a; --baseline: #383835; --ring: rgba(255,255,255,0.10);
      --series-1: #3987e5; --series-2: #199e70; --series-3: #c98500; --series-4: #008300;
      --critical: #e05252; --warning: #fab219; --good: #22b322;
    }
  }
  * { box-sizing: border-box; margin: 0; }
  body {
    background: var(--page); color: var(--ink-1);
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    line-height: 1.5; padding: 2rem 1rem; max-width: 64rem; margin: 0 auto;
  }
  h1 { font-size: 1.05rem; letter-spacing: .01em; }
  h2 { font-size: 1.05rem; margin: 0 0 .75rem; }
  .head { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .sub { color: var(--ink-2); font-size: .9rem; }
  .card {
    background: var(--surface-1); border: 1px solid var(--ring); border-radius: 16px;
    padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; overflow-x: auto;
  }
  .hero {
    border-radius: 16px; border: 1px solid var(--ring);
    padding: 2rem 2.5rem; margin-bottom: 1.25rem;
  }
  .hero.rot { background: rgba(208,59,59,.08); border-color: rgba(208,59,59,.35); }
  .hero.edge, .hero.insufficient { background: rgba(250,178,25,.10); border-color: rgba(250,178,25,.40); }
  .hero.clean { background: rgba(12,163,12,.08); border-color: rgba(12,163,12,.35); }
  .hero-word { font-weight: 800; font-size: .95rem; letter-spacing: .12em; }
  .hero.rot .hero-word, .hero.rot .hero-num { color: var(--critical); }
  .hero.edge .hero-word, .hero.edge .hero-num,
  .hero.insufficient .hero-word, .hero.insufficient .hero-num { color: var(--warning); }
  .hero.clean .hero-word, .hero.clean .hero-num { color: var(--good); }
  .hero-num {
    font-size: clamp(3.5rem, 9vw, 5.5rem); font-weight: 800; line-height: 1.05;
    letter-spacing: -0.03em; font-variant-numeric: tabular-nums;
  }
  .hero-label { color: var(--ink-2); font-size: 1.05rem; margin-bottom: .75rem; }
  .hero-text { font-size: .95rem; margin-bottom: .75rem; }
  .hero-secondary { display: flex; gap: .6rem; flex-wrap: wrap; }
  .hero-secondary span {
    background: var(--surface-1); border: 1px solid var(--ring); border-radius: 999px;
    padding: .15rem .7rem; font-size: .8rem; color: var(--ink-2);
    font-variant-numeric: tabular-nums;
  }
  .tiles { display: flex; gap: 1.25rem; flex-wrap: wrap; }
  .tile { flex: 1 1 12rem; }
  .tile .v { font-size: 2rem; font-weight: 700; font-variant-numeric: tabular-nums; }
  .tile .l { color: var(--ink-2); font-size: .85rem; }
  .tile .v.bad { color: var(--critical); }
  /* Chart text — but never the share card, whose SVG carries its own
     presentation attributes (CSS would override them in-page). */
  svg:not(#share-card) text { fill: var(--ink-muted); font-size: 11px; font-family: inherit; }
  svg .val { fill: var(--ink-2); font-weight: 600; }
  svg .ref-label { fill: var(--critical); font-weight: 600; }
  table { border-collapse: collapse; width: 100%; font-size: .85rem; }
  th, td { text-align: right; padding: .3rem .6rem; border-bottom: 1px solid var(--grid); }
  th:first-child, td:first-child { text-align: left; }
  th { color: var(--ink-2); font-weight: 600; }
  td { font-variant-numeric: tabular-nums; color: var(--ink-2); }
  td.v-rot { color: var(--critical); font-weight: 700; }
  td.v-edge, td.v-insufficient { color: var(--warning); font-weight: 700; }
  td.v-clean { color: var(--good); font-weight: 700; }
  tr.other td { color: var(--ink-muted); }
  .minis { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
           gap: 1rem; margin-top: 1rem; }
  .mini h3 { font-size: .85rem; font-weight: 600; color: var(--ink-2); margin: 0 0 .25rem; }
  .rx { margin: 0; padding-left: 1.2rem; }
  .rx li { margin-bottom: .9rem; }
  .rx .t { font-weight: 700; }
  .rx .d { color: var(--ink-2); font-size: .92rem; }
  .rx .i { color: var(--ink-muted); font-size: .85rem; }
  .share-wrap svg { width: 100%; height: auto; border-radius: 12px; }
  .share-actions { display: flex; gap: .75rem; align-items: center; margin-top: .75rem; flex-wrap: wrap; }
  .share-actions button {
    font: inherit; font-weight: 600; cursor: pointer; border-radius: 8px;
    padding: .45rem 1rem; border: 1px solid var(--ring);
    background: var(--ink-1); color: var(--page);
  }
  .share-actions button.ghost { background: transparent; color: var(--ink-1); }
  .share-note { color: var(--ink-muted); font-size: .8rem; }
  .note { color: var(--ink-muted); font-size: .8rem; margin-top: 2rem; }
  #tip {
    position: fixed; pointer-events: none; display: none; z-index: 10;
    background: var(--surface-1); border: 1px solid var(--ring); border-radius: 8px;
    padding: .4rem .6rem; font-size: .8rem; color: var(--ink-1);
    box-shadow: 0 2px 8px rgba(0,0,0,.15);
  }
</style>
</head>
<body>
<div class="head">
  <h1>contextrot — context rot report</h1>
  <p class="sub">{{ meta.sessions }} sessions · {{ meta.steps }} steps{% if meta.days %} · last {{ meta.days }} days{% endif %} · generated locally, nothing uploaded</p>
</div>

<div class="hero {{ hero.kind }}">
  <div class="hero-word">{{ headline.verdict_icon }} {{ hero.headline_word }}</div>
  <div class="hero-num">{{ hero.value }}</div>
  <div class="hero-label">{{ hero.label }}</div>
  <p class="hero-text">{{ headline.verdict_text }}</p>
  {% if hero.secondary %}
  <div class="hero-secondary">{% for s in hero.secondary %}<span>{{ s }}</span>{% endfor %}</div>
  {% endif %}
</div>

<div class="card tiles">
  <div class="tile">
    <div class="v {% if headline.ratio and headline.ratio >= 1.5 %}bad{% endif %}">{{ headline.ratio_str }}</div>
    <div class="l">deep-context vs fresh-context failure rate ({{ headline.high_rate }} vs {{ headline.low_rate }}){% if not headline.significant %} — within statistical noise{% endif %}</div>
  </div>
  <div class="tile">
    <div class="v">{{ headline.knee_str }}</div>
    <div class="l">your degradation threshold (context fill)</div>
  </div>
  <div class="tile">
    <div class="v bad">${{ '%.2f' % headline.rework_cost }}</div>
    <div class="l">token value burned in degraded steps, of ${{ '%.2f' % headline.total_cost }} total — priced at API list rates as an efficiency yardstick, not your bill</div>
  </div>
</div>

<div class="card">
  <h2>Failure-signal rate by context fill</h2>
  <svg viewBox="0 0 860 300" width="100%" role="img" aria-label="Bar chart of failure-signal rate per context-fill bucket with 95 percent confidence whiskers">
    {# y grid #}
    {% for g in chart.gridlines %}
    <line x1="60" x2="840" y1="{{ g.y }}" y2="{{ g.y }}" stroke="var(--grid)" stroke-width="1"/>
    <text x="52" y="{{ g.y + 4 }}" text-anchor="end">{{ g.label }}</text>
    {% endfor %}
    {# baseline #}
    <line x1="60" x2="840" y1="260" y2="260" stroke="var(--baseline)" stroke-width="1"/>
    {# bars #}
    {% for b in chart.bars %}
    <rect class="mark" x="{{ b.x }}" y="{{ b.y }}" width="{{ b.w }}" height="{{ b.h }}" rx="4"
          fill="{% if b.past_knee %}var(--critical){% else %}var(--series-1){% endif %}"
          {% if b.low_conf %}opacity="0.55"{% endif %}
          data-tip="{{ b.tip }}"/>
    <line x1="{{ b.cx }}" x2="{{ b.cx }}" y1="{{ b.ci_top }}" y2="{{ b.ci_bot }}" stroke="var(--ink-muted)" stroke-width="1.5"/>
    {% if b.clipped %}<text x="{{ b.cx }}" y="{{ b.ci_top - 3 }}" text-anchor="middle">▲</text>{% endif %}
    <text x="{{ b.cx }}" y="275" text-anchor="middle">{{ b.label }}</text>
    {% if b.show_val %}<text class="val" x="{{ b.cx }}" y="{{ b.y - 8 }}" text-anchor="middle">{{ b.val }}</text>{% endif %}
    {% endfor %}
    {# knee reference line #}
    {% if chart.knee_x %}
    <line x1="{{ chart.knee_x }}" x2="{{ chart.knee_x }}" y1="20" y2="260" stroke="var(--critical)" stroke-width="1.5" stroke-dasharray="5 4"/>
    <text class="ref-label" x="{{ chart.knee_x + 6 }}" y="30">degradation threshold</text>
    {% endif %}
    <text x="450" y="296" text-anchor="middle">context fill (% of {{ '{:,}'.format(meta.window) }}-token window)</text>
  </svg>
</div>

{% if reversal_rows %}
<div class="card">
  <h2>Failure-signal rate by prior reversal count</h2>
  <table>
    <thead><tr><th>Prior reversals</th><th>Steps</th><th>Degraded</th><th>Rate</th><th>95% CI</th></tr></thead>
    <tbody>
      {% for b in reversal_rows %}
      <tr><td>{{ b.range }}{% if b.low_conf %}*{% endif %}</td><td>{{ b.n }}</td><td>{{ b.degraded }}</td><td>{{ b.rate }}</td><td>{{ b.ci }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
  <p class="sub" style="margin:0.75rem 0 0">Buckets use reversals observed before the step, so same-step failures do not explain themselves. * fewer than 15 steps.</p>
</div>
{% endif %}

{% if models %}
<div class="card">
  <h2>By model</h2>
  <table>
    <thead><tr><th>Model</th><th>Steps</th><th>Fresh rate</th><th>Deep rate</th><th>Ratio</th><th>Threshold</th><th>Verdict</th></tr></thead>
    <tbody>
      {% for m in models %}
      <tr{% if m.is_other %} class="other"{% endif %}>
        <td>{{ m.label }}</td><td>{{ m.steps }}</td><td>{{ m.fresh }}</td><td>{{ m.deep }}</td>
        <td>{{ m.ratio }}</td><td>{{ m.knee }}</td>
        <td class="v-{{ m.verdict_kind }}">{% if not m.is_other %}{{ m.verdict_icon }} {{ m.verdict_kind }}{% else %}—{% endif %}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <div class="minis">
    {% for m in models %}{% if m.mini %}
    <div class="mini">
      <h3>{{ m.label }}</h3>
      <svg viewBox="0 0 280 125" width="100%" role="img" aria-label="Rot curve for {{ m.label }}">
        <line x1="10" x2="270" y1="100" y2="100" stroke="var(--baseline)" stroke-width="1"/>
        {% for b in m.mini.bars %}
        <rect class="mark" x="{{ b.x }}" y="{{ b.y }}" width="{{ b.w }}" height="{{ b.h }}" rx="2"
              fill="{% if b.past_knee %}var(--critical){% else %}var(--series-1){% endif %}"
              {% if b.low_conf %}opacity="0.55"{% endif %}
              data-tip="{{ m.label }} — {{ b.tip }}"/>
        {% endfor %}
        {% if m.mini.knee_x %}
        <line x1="{{ m.mini.knee_x }}" x2="{{ m.mini.knee_x }}" y1="10" y2="100" stroke="var(--critical)" stroke-width="1" stroke-dasharray="4 3"/>
        {% endif %}
        <text x="140" y="118" text-anchor="middle">context fill 0–100% (shared scale)</text>
      </svg>
    </div>
    {% endif %}{% endfor %}
  </div>
</div>
{% endif %}

<div class="card">
  <h2>Where your context goes (estimated)</h2>
  <svg viewBox="0 0 860 {{ comp.height }}" width="100%" role="img" aria-label="Horizontal bar chart of estimated context composition">
    {% for r in comp.rows %}
    <text x="0" y="{{ r.y + 13 }}" class="val" text-anchor="start">{{ r.label }}</text>
    <rect class="mark" x="200" y="{{ r.y }}" width="{{ r.w }}" height="18" rx="4" fill="{{ r.color }}" data-tip="{{ r.tip }}"/>
    <text x="{{ 208 + r.w }}" y="{{ r.y + 13 }}" text-anchor="start">{{ r.val }}</text>
    {% endfor %}
  </svg>
  <p class="sub" style="margin:0.75rem 0 0">Per-session averages, estimated at 4 chars/token. Startup overhead is <strong>{{ '%.0f' % comp.overhead_pct }}%</strong> of your context window — loaded before your first word, every session.</p>
</div>

{% if prescriptions %}
<div class="card">
  <h2>Prescriptions</h2>
  <ol class="rx">
    {% for p in prescriptions %}
    <li><div class="t">{{ p.title }}</div><div class="d">{{ p.detail }}</div><div class="i">{{ p.impact }}</div></li>
    {% endfor %}
  </ol>
</div>
{% endif %}

<div class="card share-wrap">
  <h2>Share card</h2>
  {# Pure-SVG card, fixed dark palette, literal hex colors (CSS vars don't
     survive serialization). Deliberately NO xmlns attribute here: the report
     must contain no absolute-URL substrings, and XMLSerializer re-adds the
     SVG namespace automatically when the export script serializes the node.
     Do not "fix" this by adding xmlns. #}
  <svg id="share-card" viewBox="0 0 1200 630" width="1200" height="630"
       font-family="ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Arial, sans-serif">
    <rect x="0" y="0" width="1200" height="630" fill="{{ card.bg }}"/>
    <rect x="1" y="1" width="1198" height="628" fill="none" stroke="{{ card.grid }}" stroke-width="2" rx="18"/>
    <text x="60" y="82" fill="{{ card.ink }}" font-size="34" font-weight="700">contextrot</text>
    <rect x="248" y="52" rx="17" height="38"
          width="{{ 40 + card.hero.headline_word|length * 12 }}"
          fill="none" stroke="{{ card.accent }}" stroke-width="2"/>
    <text x="{{ 268 + card.hero.headline_word|length * 6 }}" y="78" fill="{{ card.accent }}"
          font-size="19" font-weight="700" letter-spacing="2" text-anchor="middle">{{ card.hero.headline_word }}</text>
    <text x="60" y="330" fill="{{ card.accent }}" font-size="160" font-weight="800"
          letter-spacing="-6">{{ card.hero.value }}</text>
    <text x="60" y="385" fill="{{ card.ink }}" font-size="28" font-weight="600">{{ card.hero.label }}</text>
    {% for line in card.verdict_lines %}
    <text x="60" y="{{ 432 + loop.index0 * 32 }}" fill="{{ card.muted }}" font-size="21">{{ line }}</text>
    {% endfor %}
    {# mini rot curve, right side #}
    <line x1="640" x2="1140" y1="470" y2="470" stroke="{{ card.grid }}" stroke-width="2"/>
    {% for b in card.chart.bars %}
    <rect x="{{ b.x }}" y="{{ b.y }}" width="{{ b.w }}" height="{{ b.h }}" rx="4"
          fill="{% if b.past_knee %}{{ card.accent }}{% else %}{{ card.bar }}{% endif %}"
          {% if b.low_conf %}opacity="0.55"{% endif %}/>
    {% endfor %}
    {% if card.chart.knee_x %}
    <line x1="{{ card.chart.knee_x }}" x2="{{ card.chart.knee_x }}" y1="170" y2="470" stroke="{{ card.accent }}" stroke-width="2" stroke-dasharray="8 6"/>
    {% endif %}
    <text x="890" y="500" fill="{{ card.muted }}" font-size="18" text-anchor="middle">failure rate by context fill (0–100%)</text>
    <line x1="60" x2="1140" y1="548" y2="548" stroke="{{ card.grid }}" stroke-width="1"/>
    <text x="60" y="586" fill="{{ card.muted }}" font-size="20">{{ card.footer }}</text>
  </svg>
  <div class="share-actions">
    <button type="button" id="save-png">Save as PNG</button>
    <button type="button" id="save-svg" class="ghost">Download SVG</button>
    <span class="share-note" id="share-note">1200×630 — sized for X/Reddit/OG previews.</span>
  </div>
</div>

<div class="card">
  <h2>Bucket data</h2>
  <table>
    <thead><tr><th>Fill</th><th>Steps</th><th>Degraded</th><th>Rate</th><th>95% CI</th>
      <th>Tool err</th><th>Edit fail</th><th>Retry</th><th>Re-read</th><th>Self-corr</th></tr></thead>
    <tbody>
      {% for b in table_rows %}
      <tr><td>{{ b.range }}</td><td>{{ b.n }}</td><td>{{ b.degraded }}</td><td>{{ b.rate }}</td><td>{{ b.ci }}</td>
        <td>{{ b.tool_error }}</td><td>{{ b.edit_failure }}</td><td>{{ b.retry }}</td><td>{{ b.reread }}</td><td>{{ b.self_correction }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<p class="note">Observational diagnostic computed locally from your own agent transcripts — not a controlled experiment.
Rates are failure-signal frequencies with Wilson 95% intervals; composition figures are estimates.
Generated by contextrot v{{ meta.version }}.</p>

<div id="tip"></div>
<script>
(function () {
  var tip = document.getElementById('tip');
  document.querySelectorAll('.mark').forEach(function (el) {
    el.addEventListener('mousemove', function (e) {
      tip.textContent = el.getAttribute('data-tip');
      tip.style.display = 'block';
      tip.style.left = (e.clientX + 14) + 'px';
      tip.style.top = (e.clientY + 14) + 'px';
    });
    el.addEventListener('mouseleave', function () { tip.style.display = 'none'; });
  });

  function serializeCard() {
    return new XMLSerializer().serializeToString(document.getElementById('share-card'));
  }
  function download(blob, name) {
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = name;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(function () { URL.revokeObjectURL(a.href); }, 1000);
  }
  function saveSVG() {
    download(new Blob([serializeCard()], { type: 'image/svg+xml' }), 'contextrot-card.svg');
  }
  function savePNG() {
    var xml = serializeCard();
    var img = new Image();
    var W = 2400, H = 1260; // 2x for crispness
    function fallback() {
      saveSVG();
      document.getElementById('share-note').textContent =
        'PNG export not supported here — saved as SVG instead (drag into any chat/post).';
    }
    img.onload = function () {
      try {
        var c = document.createElement('canvas');
        c.width = W; c.height = H;
        c.getContext('2d').drawImage(img, 0, 0, W, H);
        c.toBlob(function (blob) {
          if (blob) download(blob, 'contextrot-card.png'); else fallback();
        }, 'image/png');
      } catch (e) { fallback(); }
    };
    img.onerror = fallback;
    img.src = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(xml);
  }
  document.getElementById('save-png').addEventListener('click', savePNG);
  document.getElementById('save-svg').addEventListener('click', saveSVG);
})();
</script>
</body>
</html>
